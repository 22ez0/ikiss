{
  "version": 2,
  "buildCommand": "pnpm run build",
  "functions": {
    "api/handler.mjs": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/bot-handler.js": {
      "memory": 128,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/bot/:path*",
      "destination": "/api/bot-handler.js"
    },
    {
      "source": "/api/bot",
      "destination": "/api/bot-handler.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/handler.mjs"
    }
  ]
}
