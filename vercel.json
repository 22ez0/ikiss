{
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30,
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
